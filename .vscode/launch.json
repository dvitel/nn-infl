{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Preprocess: GLUE QNLI",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "preprocess", "--task=qnli", "--tokenizer-name=distilbert/distilroberta-base"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Fitetune: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "finetune", "--task=qnli", "--model=distilbert/distilroberta-base", "--num-epochs=5"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Grad: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "grads", "--task=qnli"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Infl: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "infl", "--task=qnli", "--compute-accurate"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Finetune2: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "finetune2", "--task=qnli", "--infl-key=influences", "--num-epochs=1"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        }        
    ]
}