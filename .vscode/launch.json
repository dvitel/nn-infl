{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Preprocess: GLUE QNLI",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "preprocess", "--task=qnli", "--tokenizer-name=distilbert/distilroberta-base"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Preprocess: CIFAR10",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp_resnet.py",
            "console": "integratedTerminal",
            "args": [
                "preprocess", "--dataset=cifar10"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },   
        {
            "name": "Finetune: ResNet34 on CIFAR10",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp_resnet.py",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "args": [
                "finetune", "--dataset-path=./data/dev/d_cifar10_0", "--model-name=resnet34", "--noise-type=worst", "--num-epochs=2"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },     
        {
            "name": "Checkpoint: ResNet34 on CIFAR10",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp_resnet.py",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "args": [
                "checkpoint", "--cp=./data/dev/m_cifar10_resnet34_0"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },        
        {
            "name": "Grad: ResNet34 on CIFAR10",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp_resnet.py",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "args": [
                "grads", "--dataset-name=cifar10", "--model-name=resnet34"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },         
        {
            "name": "Infl: ResNet34 on CIFAR10",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp_resnet.py",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "args": [
                "infl", "--dataset-name=cifar10", "--model-name=resnet34", "--method=datainf", "--size-koef=0.8"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },                            
        {
            "name": "Fitetune: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "finetune", "--task=qnli", "--model=distilbert/distilroberta-base", "--num-epochs=2"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Grad: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "grads", "--task=qnli"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },        
        {
            "name": "Infl: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "infl", "--task=qnli", "--methods=lissa", "--with-grads"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        },
        {
            "name": "Finetune2: GLUE QNLI on DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "finetune2", "--task=qnli", "--filter-method=infl", "--infl-method=hf", "--num-epochs=1", "--module-pattern=.*\\.layer\\.(1[6-9]|2[0-3])\\..*\\.lora_(A|B)\\..*"
            ],
            "env": {
                "INFL_SEED": "0",
                "INFL_CWD": "./data/dev"
            }
        }        
    ]
}