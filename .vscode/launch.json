{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Infl: GLUE QNLI with DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "infl", "--run-id=0", "--task=qnli", "--model=distilbert/distilroberta-base", "--num-epochs=3"
            ]
        },
        {
            "name": "Metrics: GLUE QNLI with DistilRoberta",
            "type": "debugpy",
            "request": "launch",
            "program": "src/exp.py",
            "console": "integratedTerminal",
            "args": [
                "filter", "--run-id=0", "--task=qnli", "--num-epochs=3"
            ],
            "env": {
                "CUDA_LAUNCH_BLOCKING": "1"
            }
        }
    ]
}